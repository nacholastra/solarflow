# ─── Públicas (cliente + servidor) ───────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key
NEXT_PUBLIC_APP_URL=https://solarflow-kappa.vercel.app
NEXT_PUBLIC_PAYPAL_CLIENT_ID=tu-paypal-client-id

# Opcional: analítica (solo se carga tras consentimiento de cookies)
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_EUR_TO_USD_RATE=1.09

# Datos legales (dejar vacíos hasta tener CIF/razón social)
NEXT_PUBLIC_LEGAL_NAME=
NEXT_PUBLIC_LEGAL_CIF=
NEXT_PUBLIC_LEGAL_ADDRESS=

# ─── Solo servidor ───────────────────────────────────────────────────────────
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# PayPal (modo live en producción)
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_MODE=live
PAYPAL_PLAN_ID_BASIC_EUR=
PAYPAL_PLAN_ID_BASIC_USD=
PAYPAL_PLAN_ID_PRO_EUR=
PAYPAL_PLAN_ID_PRO_USD=

# Planes PayPal con descuento early bird (−30%: Basic 42€ / Pro 70€). Opcional.
# Si no están, el early bird se guarda en la cuenta y se usa el plan regular hasta configurarlas.
PAYPAL_PLAN_ID_BASIC_EUR_LAUNCH=
PAYPAL_PLAN_ID_BASIC_USD_LAUNCH=
PAYPAL_PLAN_ID_PRO_EUR_LAUNCH=
PAYPAL_PLAN_ID_PRO_USD_LAUNCH=

# Panel admin interno (independiente de Supabase Auth)
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Email transaccional (Resend: https://resend.com)
RESEND_API_KEY=
EMAIL_FROM=SolarFlow <soporte@solarflow.app>
CONTACT_NOTIFY_EMAIL=soporte@solarflow.app

# Seguridad opcional
LEAD_IP_SALT=

# Solo desarrollo — NUNCA en producción
ALLOW_TEST_PLAN=false

# Cron Vercel (expire trials diarios). Genera un secreto largo.
CRON_SECRET=

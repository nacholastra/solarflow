# ── Supabase (obligatorio) ──────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── App (obligatorio en producción) ─────────────────────────────────
NEXT_PUBLIC_APP_URL=https://solarflow-kappa.vercel.app

# ── PayPal ──────────────────────────────────────────────────────────
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
PAYPAL_WEBHOOK_ID=
PAYPAL_PLAN_ID_BASIC_EUR=
PAYPAL_PLAN_ID_BASIC_USD=
PAYPAL_PLAN_ID_PRO_EUR=
PAYPAL_PLAN_ID_PRO_USD=
NEXT_PUBLIC_EUR_TO_USD_RATE=1.09

# ── Panel admin (independiente de Supabase Auth) ────────────────────
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# ── Analytics (opcional) ───────────────────────────────────────────
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GTM_ID=

# ── Seguridad / desarrollo ──────────────────────────────────────────
# Salt para hash de IP en leads (opcional; usa service role key como fallback)
LEAD_IP_SALT=
# Solo en desarrollo: activar plan Basic de prueba sin PayPal
ALLOW_TEST_PLAN=false
